@model EFC.Models.Order

@{
    ViewData["Title"] = "Delete Order";
}

<h3>Are you sure you want to delete this order?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.OrderDate.ToShortDateString()</dd>
        <dt class="col-sm-2">Customer</dt>
        <dd class="col-sm-10">@Model.Customer.LastName</dd>
        <dt class="col-sm-2">Supermarket</dt>
        <dd class="col-sm-10">@Model.SuperMarket.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>